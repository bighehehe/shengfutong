---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="页面未找到 - 盛付通POS">
  <Navbar />
  <main class="flex-grow flex items-center justify-center bg-gray-50 min-h-[60vh]">
    <div class="text-center px-4">
      <h1 class="text-9xl font-extrabold text-gray-200">404</h1>
      <h2 class="text-3xl font-bold text-gray-900 mt-4 mb-2">页面未找到</h2>
      <p class="text-gray-500 mb-8">抱歉，您访问的页面不存在或已被移除。</p>
      <a href="/" class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-white bg-primary hover:bg-red-700 transition-all">
        返回首页
      </a>
    </div>
  </main>
  <Footer />
</Layout>
