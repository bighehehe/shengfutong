---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="联系我们 - 盛付通POS">
  <Navbar />
  <main class="flex-grow bg-gray-50 min-h-screen py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl font-extrabold text-gray-900">联系我们</h1>
        <p class="mt-4 text-lg text-gray-600">
          无论您是需要办理机器，还是寻求商务合作，我们都随时欢迎您的咨询
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Contact Info -->
        <div>
          <div class="bg-white rounded-2xl shadow-lg p-8 mb-8">
            <h3 class="text-2xl font-bold text-gray-900 mb-6">联系方式</h3>
            <div class="space-y-6">
              <div class="flex items-start">
                <div class="bg-red-100 p-3 rounded-full mr-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E60012" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                <div>
                  <p class="text-sm text-gray-500 font-medium uppercase tracking-wide">客服热线</p>
                  <p class="text-xl font-bold text-gray-900">400-926-6655</p>
                </div>
              </div>
              <div class="flex items-start">
                <div class="bg-red-100 p-3 rounded-full mr-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E60012" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </div>
                <div>
                  <p class="text-sm text-gray-500 font-medium uppercase tracking-wide">商务邮箱</p>
                  <p class="text-xl font-bold text-gray-900">bd@shengpay-pos.com</p>
                </div>
              </div>
              <div class="flex items-start">
                <div class="bg-red-100 p-3 rounded-full mr-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E60012" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <div>
                  <p class="text-sm text-gray-500 font-medium uppercase tracking-wide">公司地址</p>
                  <p class="text-lg text-gray-900">上海市浦东新区张江高科园区盛大创新园</p>
                </div>
              </div>
              <div class="flex items-start">
                <div class="bg-red-100 p-3 rounded-full mr-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E60012" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <div>
                  <p class="text-sm text-gray-500 font-medium uppercase tracking-wide">工作时间</p>
                  <p class="text-lg text-gray-900">周一至周日 9:00 - 21:00</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Form -->
        <div class="bg-white rounded-2xl shadow-lg p-8 lg:p-12">
          <h3 class="text-2xl font-bold text-gray-900 mb-6">在线留言</h3>
          <form id="contact-form" class="space-y-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">您的姓名</label>
              <input 
                type="text" 
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition"
                placeholder="请输入您的姓名"
                name="name"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">联系电话</label>
              <input 
                type="tel" 
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition"
                placeholder="请输入您的手机号码"
                name="phone"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">咨询类型</label>
              <select 
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition"
                name="type"
              >
                <option value="personal">个人办理POS机</option>
                <option value="business">商户收款方案</option>
                <option value="agent">代理加盟合作</option>
                <option value="support">售后服务</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">留言内容</label>
              <textarea 
                rows={4}
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition"
                placeholder="请简要描述您的需求..."
                name="message"
              ></textarea>
            </div>
            <button 
              type="submit"
              class="w-full bg-primary text-white font-bold py-4 rounded-lg hover:bg-red-700 transition shadow-lg"
            >
              提交申请
            </button>
          </form>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      alert('感谢您的提交！我们的客户经理将在24小时内联系您。');
      form.reset();
    });
  }
</script>
